# Flask Settings
SECRET_KEY=your_secret_key_here
DEBUG=True
PORT=5000
HOST=0.0.0.0

# Database Settings
# For SQLite, leave these commented or empty
# For MySQL, uncomment and fill in your details
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=online_store

# Set this to 'mysql' to use MySQL, otherwise defaults to sqlite
DB_TYPE=sqlite
