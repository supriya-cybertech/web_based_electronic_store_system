# Flask Settings
SECRET_KEY=your_secret_key_here
DEBUG=True
PORT=5000
HOST=0.0.0.0

# Database Settings
# For SQLite, leave these commented or empty
# DB_TYPE=sqlite

# For Supabase / PostgreSQL
# DB_TYPE=postgres
# DB_USER=postgres
# DB_PASSWORD=your_supabase_password
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_NAME=postgres

# For MySQL
# DB_TYPE=mysql
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=online_store
